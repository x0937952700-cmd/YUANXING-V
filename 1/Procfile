web: sh -c 'APP_DIR="."; if [ ! -f wsgi.py ]; then FOUND_WSGI=$(find . -maxdepth 2 -name wsgi.py -not -path "./.venv/*" | head -n 1); if [ -n "$FOUND_WSGI" ]; then APP_DIR=$(dirname "$FOUND_WSGI"); fi; fi; cd "$APP_DIR" && export YX_STARTUP_DB_INIT=skip YX_STARTUP_DB_CHECK=0 && gunicorn wsgi:app --bind 0.0.0.0:${PORT:-10000} --workers 1 --threads 4 --timeout 120 --access-logfile - --error-logfile - --log-level info'
